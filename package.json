{
  "name": "dose-o-clock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:http": "vite --mode codex",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint .",
    "test": "vitest run",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^0.21.1",
    "vue": "^3.5.13",
    "vue-facing-decorator": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.2",
    "@frontlobby/eslint-config-lcb": "github:frontlobby/eslint-config-lcb",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^10.5.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "vue-tsc": "^2.1.10",
    "wrangler": "^4.104.0"
  }
}
